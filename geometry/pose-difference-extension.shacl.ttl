# SPDX-License-Identifier: MPL-2.0
@prefix geom-rel:      <https://comp-rob2b.github.io/metamodels/geometry/spatial-relations#> .
@prefix geom-rel-ext:  <https://secorolab.github.io/metamodels/geometry/spatial-relations#> .
@prefix geom:          <https://comp-rob2b.github.io/metamodels/geometry/structural-entities#> .
@prefix geom-coord:    <https://comp-rob2b.github.io/metamodels/geometry/coordinates#> .
@prefix geom-coord-ext: <https://secorolab.github.io/metamodels/geometry/coordinates#> .
@prefix rdfs:          <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:            <http://www.w3.org/ns/shacl#> .

# Secorolab extension: a pose difference is the geometric error between two poses.
# It is NOT a pose (not a frame) and NOT an acceleration twist (that typing belongs
# only to the ACHD control-signal side). Its coordinate carries two vectors: a
# position-difference (linear part, Length) and an orientation-difference rotation
# vector (angular part, Angle). An implementation may store it as a KDL twist, but
# that representation is impl-specific and does not change these semantics.
geom-rel-ext:PoseDifference
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass geom-rel-ext:PoseDifference ;
    sh:property [
        sh:path geom-rel:of ;
        sh:class geom:Frame ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path geom-rel:with-respect-to ;
        sh:class geom:Frame ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] .

geom-coord-ext:PoseDifferenceCoordinate
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass geom-coord-ext:PoseDifferenceCoordinate ;
    sh:property [
        sh:path geom-coord-ext:linear ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class geom-coord:VectorXYZ ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] ;
    sh:property [
        sh:path geom-coord-ext:angular ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class geom-coord:VectorXYZ ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] .
