{
    "@context": {
        "@version": 1.1,
        "msrun": "https://secorolab.github.io/motion-spec/runtime/",

        "Frame": {
            "@id": "msrun:Frame",
            "@context": {
                "activeState": { "@id": "msrun:activeState", "@type": "@id" },
                "step": "msrun:step"
            }
        },

        "StateOccurrence": {
            "@id": "msrun:StateOccurrence",
            "@context": {
                "atFrame": { "@id": "msrun:atFrame", "@type": "@id" },
                "state": { "@id": "msrun:state", "@type": "@id" }
            }
        },

        "TransitionOccurrence": {
            "@id": "msrun:TransitionOccurrence",
            "@context": {
                "atFrame": { "@id": "msrun:atFrame", "@type": "@id" },
                "event": { "@id": "msrun:event", "@type": "@id" },
                "fromState": { "@id": "msrun:fromState", "@type": "@id" },
                "toState": { "@id": "msrun:toState", "@type": "@id" },
                "transition": { "@id": "msrun:transition", "@type": "@id" }
            }
        },

        "EventOccurrence": {
            "@id": "msrun:EventOccurrence",
            "@context": {
                "atFrame": { "@id": "msrun:atFrame", "@type": "@id" },
                "event": { "@id": "msrun:event", "@type": "@id" },
                "fsmState": { "@id": "msrun:fsmState", "@type": "@id" },
                "slotIndex": "msrun:slotIndex"
            }
        },

        "MonitorOccurrence": {
            "@id": "msrun:MonitorOccurrence",
            "@context": {
                "atFrame": { "@id": "msrun:atFrame", "@type": "@id" },
                "constraint": { "@id": "msrun:constraint", "@type": "@id" },
                "event": { "@id": "msrun:event", "@type": "@id" },
                "fsmState": { "@id": "msrun:fsmState", "@type": "@id" },
                "monitor": { "@id": "msrun:monitor", "@type": "@id" },
                "slotIndex": "msrun:slotIndex",
                "value": "msrun:value"
            }
        },

        "ConstraintSatisfiedOccurrence": {
            "@id": "msrun:ConstraintSatisfiedOccurrence",
            "@context": {
                "atFrame": { "@id": "msrun:atFrame", "@type": "@id" },
                "constraint": { "@id": "msrun:constraint", "@type": "@id" },
                "controller": { "@id": "msrun:controller", "@type": "@id" },
                "fsmState": { "@id": "msrun:fsmState", "@type": "@id" },
                "slotIndex": "msrun:slotIndex",
                "value": "msrun:value"
            }
        },

        "ConstraintUnsatisfiedOccurrence": {
            "@id": "msrun:ConstraintUnsatisfiedOccurrence",
            "@context": {
                "atFrame": { "@id": "msrun:atFrame", "@type": "@id" },
                "constraint": { "@id": "msrun:constraint", "@type": "@id" },
                "controller": { "@id": "msrun:controller", "@type": "@id" },
                "fsmState": { "@id": "msrun:fsmState", "@type": "@id" },
                "slotIndex": "msrun:slotIndex",
                "value": "msrun:value"
            }
        },

        "contractVersion": "msrun:contractVersion",
        "frameCount": "msrun:frameCount",
        "runId": "msrun:runId"
    }
}
