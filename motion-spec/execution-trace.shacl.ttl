@prefix ms-exec-trace: <https://secorolab.github.io/metamodels/motion-spec/execution-trace/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ms-exec-trace:Frame
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass ms-exec-trace:Frame ;
    sh:message "A trace frame needs a non-negative step and may name one active state and generation time." ;
    # Tick index: one frame per control cycle. Many occurrences may share a
    # frame; step orders frames, seq (below) orders occurrences within one.
    sh:property [
        sh:path ms-exec-trace:step ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0
    ] ;
    sh:property [
        sh:path ms-exec-trace:activeState ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] ;
    sh:property [
        sh:path prov:generatedAtTime ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime
    ] .

ms-exec-trace:OccurrenceShape
    a sh:NodeShape ;
    sh:message "Every occurrence must identify one trace frame and one non-negative run-global sequence number." ;
    sh:property [
        sh:path ms-exec-trace:atFrame ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class ms-exec-trace:Frame ;
        sh:nodeKind sh:IRI
    ] ;
    # Run-global monotonic counter; totally orders occurrences, including those
    # sharing a frame (step) when several fire in the same tick.
    sh:property [
        sh:path ms-exec-trace:seq ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0
    ] ;
    sh:property [
        sh:path prov:generatedAtTime ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime
    ] .

ms-exec-trace:StateOccurrence
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass ms-exec-trace:StateOccurrence ;
    sh:message "A state occurrence must identify one state and one ordered trace frame." ;
    sh:node ms-exec-trace:OccurrenceShape ;
    sh:property [
        sh:path ms-exec-trace:state ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] .

ms-exec-trace:TransitionOccurrence
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass ms-exec-trace:TransitionOccurrence ;
    sh:message "A transition occurrence must identify one transition and one ordered trace frame." ;
    sh:node ms-exec-trace:OccurrenceShape ;
    sh:property [
        sh:path ms-exec-trace:transition ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] .

ms-exec-trace:EventOccurrence
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass ms-exec-trace:EventOccurrence ;
    sh:message "An event occurrence must identify one event and one ordered trace frame." ;
    sh:node ms-exec-trace:OccurrenceShape ;
    sh:property [
        sh:path ms-exec-trace:event ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] .

ms-exec-trace:MonitorOccurrence
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass ms-exec-trace:MonitorOccurrence ;
    sh:message "A monitor occurrence must identify one monitor and one ordered trace frame; its value must be numeric when present." ;
    sh:node ms-exec-trace:OccurrenceShape ;
    sh:property [
        sh:path ms-exec-trace:monitor ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] ;
    sh:property ms-exec-trace:NumericValueShape .

ms-exec-trace:NumericValueShape
    a sh:PropertyShape ;
    sh:path ms-exec-trace:value ;
    sh:maxCount 1 ;
    sh:or (
        [ sh:datatype xsd:decimal ]
        [ sh:datatype xsd:double ]
    ) .
