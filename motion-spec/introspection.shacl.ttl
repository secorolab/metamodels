@prefix ms-intro: <https://secorolab.github.io/metamodels/motion-spec/introspection/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rt: <https://secorolab.github.io/metamodels/runtime#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ms-intro:Frame
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass ms-intro:Frame ;
    sh:property [
        sh:path ms-intro:step ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0
    ] ;
    sh:property [
        sh:path ms-intro:activeState ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] ;
    sh:property [
        sh:path prov:generatedAtTime ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime
    ] .

ms-intro:RuntimeRunShape
    a sh:NodeShape ;
    sh:targetSubjectsOf ms-intro:runId ;
    sh:class rt:Runtime ;
    sh:property [
        sh:path ms-intro:runId ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path ms-intro:contractVersion ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1
    ] ;
    sh:property [
        sh:path ms-intro:frameCount ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0
    ] ;
    sh:property [
        sh:path prov:wasGeneratedBy ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] .

ms-intro:OccurrenceShape
    a sh:NodeShape ;
    sh:property [
        sh:path ms-intro:atFrame ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class ms-intro:Frame ;
        sh:nodeKind sh:IRI
    ] ;
    sh:property [
        sh:path prov:generatedAtTime ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime
    ] .

ms-intro:StateOccurrence
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass ms-intro:StateOccurrence ;
    sh:node ms-intro:OccurrenceShape ;
    sh:property [
        sh:path ms-intro:state ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] .

ms-intro:TransitionOccurrence
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass ms-intro:TransitionOccurrence ;
    sh:node ms-intro:OccurrenceShape ;
    sh:property [
        sh:path ms-intro:transition ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] ;
    sh:property [
        sh:path ms-intro:fromState ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] ;
    sh:property [
        sh:path ms-intro:toState ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] ;
    sh:property [
        sh:path ms-intro:event ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] .

ms-intro:EventOccurrence
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass ms-intro:EventOccurrence ;
    sh:node ms-intro:OccurrenceShape ;
    sh:property [
        sh:path ms-intro:event ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] ;
    sh:property [
        sh:path ms-intro:fsmState ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] ;
    sh:property [
        sh:path ms-intro:slotIndex ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0
    ] .

ms-intro:MonitorOccurrence
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass ms-intro:MonitorOccurrence ;
    sh:node ms-intro:OccurrenceShape ;
    sh:property [
        sh:path ms-intro:monitor ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] ;
    sh:property ms-intro:OptionalConstraintShape, ms-intro:OptionalEventShape,
        ms-intro:OptionalStateShape, ms-intro:SlotIndexShape, ms-intro:NumericValueShape .

ms-intro:ConstraintSatisfiedOccurrence
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass ms-intro:ConstraintSatisfiedOccurrence ;
    sh:node ms-intro:ConstraintOccurrenceShape .

ms-intro:ConstraintUnsatisfiedOccurrence
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass ms-intro:ConstraintUnsatisfiedOccurrence ;
    sh:node ms-intro:ConstraintOccurrenceShape .

ms-intro:ConstraintOccurrenceShape
    a sh:NodeShape ;
    sh:node ms-intro:OccurrenceShape ;
    sh:property [
        sh:path ms-intro:constraint ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] ;
    sh:property [
        sh:path ms-intro:controller ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI
    ] ;
    sh:property ms-intro:OptionalStateShape, ms-intro:SlotIndexShape, ms-intro:NumericValueShape .

ms-intro:OptionalConstraintShape
    a sh:PropertyShape ;
    sh:path ms-intro:constraint ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI .

ms-intro:OptionalEventShape
    a sh:PropertyShape ;
    sh:path ms-intro:event ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI .

ms-intro:OptionalStateShape
    a sh:PropertyShape ;
    sh:path ms-intro:fsmState ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI .

ms-intro:SlotIndexShape
    a sh:PropertyShape ;
    sh:path ms-intro:slotIndex ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:integer ;
    sh:minInclusive 0 .

ms-intro:NumericValueShape
    a sh:PropertyShape ;
    sh:path ms-intro:value ;
    sh:maxCount 1 ;
    sh:or (
        [ sh:datatype xsd:decimal ]
        [ sh:datatype xsd:double ]
    ) .

ms-intro:ForbiddenLegacySampleShape
    a sh:NodeShape ;
    sh:targetSubjectsOf rdf:type ;
    sh:not [
        sh:or (
            [ sh:class ms-intro:ControllerSample ]
            [ sh:class ms-intro:SignalSample ]
            [ sh:class ms-intro:MonitorSample ]
        )
    ] .

ms-intro:ForbiddenLegacyPredicateShape
    a sh:NodeShape ;
    sh:targetSubjectsOf ms-intro:compute_ns, ms-intro:error, ms-intro:measured, ms-intro:output,
        ms-intro:period_ns, ms-intro:satSince, ms-intro:setpoint, ms-intro:t, ms-intro:wall_ns ;
    sh:property [ sh:path ms-intro:compute_ns ; sh:maxCount 0 ] ;
    sh:property [ sh:path ms-intro:error ; sh:maxCount 0 ] ;
    sh:property [ sh:path ms-intro:measured ; sh:maxCount 0 ] ;
    sh:property [ sh:path ms-intro:output ; sh:maxCount 0 ] ;
    sh:property [ sh:path ms-intro:period_ns ; sh:maxCount 0 ] ;
    sh:property [ sh:path ms-intro:satSince ; sh:maxCount 0 ] ;
    sh:property [ sh:path ms-intro:setpoint ; sh:maxCount 0 ] ;
    sh:property [ sh:path ms-intro:t ; sh:maxCount 0 ] ;
    sh:property [ sh:path ms-intro:wall_ns ; sh:maxCount 0 ] .
