{
    "@context": {
        "@version": 1.1,
        "ms-intro": "https://secorolab.github.io/metamodels/motion-spec/introspection/",
        "xsd": "http://www.w3.org/2001/XMLSchema#",

        "Frame": {
            "@id": "ms-intro:Frame",
            "@context": {
                "activeState": { "@id": "ms-intro:activeState", "@type": "@id" },
                "step": "ms-intro:step"
            }
        },

        "StateOccurrence": {
            "@id": "ms-intro:StateOccurrence",
            "@context": {
                "atFrame": { "@id": "ms-intro:atFrame", "@type": "@id" },
                "state": { "@id": "ms-intro:state", "@type": "@id" }
            }
        },

        "TransitionOccurrence": {
            "@id": "ms-intro:TransitionOccurrence",
            "@context": {
                "atFrame": { "@id": "ms-intro:atFrame", "@type": "@id" },
                "event": { "@id": "ms-intro:event", "@type": "@id" },
                "fromState": { "@id": "ms-intro:fromState", "@type": "@id" },
                "toState": { "@id": "ms-intro:toState", "@type": "@id" },
                "transition": { "@id": "ms-intro:transition", "@type": "@id" }
            }
        },

        "EventOccurrence": {
            "@id": "ms-intro:EventOccurrence",
            "@context": {
                "atFrame": { "@id": "ms-intro:atFrame", "@type": "@id" },
                "event": { "@id": "ms-intro:event", "@type": "@id" },
                "fsmState": { "@id": "ms-intro:fsmState", "@type": "@id" },
                "slotIndex": "ms-intro:slotIndex"
            }
        },

        "MonitorOccurrence": {
            "@id": "ms-intro:MonitorOccurrence",
            "@context": {
                "atFrame": { "@id": "ms-intro:atFrame", "@type": "@id" },
                "constraint": { "@id": "ms-intro:constraint", "@type": "@id" },
                "event": { "@id": "ms-intro:event", "@type": "@id" },
                "fsmState": { "@id": "ms-intro:fsmState", "@type": "@id" },
                "monitor": { "@id": "ms-intro:monitor", "@type": "@id" },
                "slotIndex": "ms-intro:slotIndex",
                "value": "ms-intro:value"
            }
        },

        "ConstraintSatisfiedOccurrence": {
            "@id": "ms-intro:ConstraintSatisfiedOccurrence",
            "@context": {
                "atFrame": { "@id": "ms-intro:atFrame", "@type": "@id" },
                "constraint": { "@id": "ms-intro:constraint", "@type": "@id" },
                "controller": { "@id": "ms-intro:controller", "@type": "@id" },
                "fsmState": { "@id": "ms-intro:fsmState", "@type": "@id" },
                "slotIndex": "ms-intro:slotIndex",
                "value": "ms-intro:value"
            }
        },

        "ConstraintUnsatisfiedOccurrence": {
            "@id": "ms-intro:ConstraintUnsatisfiedOccurrence",
            "@context": {
                "atFrame": { "@id": "ms-intro:atFrame", "@type": "@id" },
                "constraint": { "@id": "ms-intro:constraint", "@type": "@id" },
                "controller": { "@id": "ms-intro:controller", "@type": "@id" },
                "fsmState": { "@id": "ms-intro:fsmState", "@type": "@id" },
                "slotIndex": "ms-intro:slotIndex",
                "value": "ms-intro:value"
            }
        },

        "contractVersion": { "@id": "ms-intro:contractVersion", "@type": "xsd:integer" },
        "frameCount": { "@id": "ms-intro:frameCount", "@type": "xsd:integer" },
        "runId": { "@id": "ms-intro:runId", "@type": "xsd:string" }
    }
}
