{
    "@context": {
        "@version": 1.1,
        "rec": "https://secorolab.github.io/metamodels/rec#",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "dcat": "http://www.w3.org/ns/dcat#",
        "Repository": "rec:Repository",
        "Dependency": "rec:Dependency",
        "Host": "rec:Host",
        "Metric": "rec:Metric",
        "SourceFile": "rec:SourceFile",
        "PathLocation": "rec:PathLocation",
        "path": "rec:path",
        "sha256": "rec:sha256",
        "size_bytes": {
            "@id": "rec:size-bytes",
            "@type": "xsd:integer"
        },
        "QueuedRun": "rec:QueuedRun",
        "RunningRun": "rec:RunningRun",
        "CompletedRun": "rec:CompletedRun",
        "FailedRun": "rec:FailedRun",
        "InterruptedRun": "rec:InterruptedRun",
        "CancelledRun": "rec:CancelledRun",
        "run_id": "rec:run-id",
        "file_id": "rec:file-id",
        "label": "rec:label",
        "version": "dcat:version",
        "repositories": {
            "@id": "rec:repositories",
            "@container": "@set"
        },
        "dependencies": {
            "@id": "rec:dependencies",
            "@container": "@set"
        },
        "host_info": "rec:host-info",
        "agents": {
            "@id": "rec:agents",
            "@container": "@set"
        },
        "activities": {
            "@id": "rec:activities",
            "@container": "@set"
        },
        "resources": {
            "@id": "rec:resources",
            "@container": "@set"
        },
        "artefacts": {
            "@id": "rec:artefacts",
            "@container": "@set"
        },
        "metrics": {
            "@id": "rec:metrics",
            "@container": "@set"
        },
        "step": {
            "@id": "rec:step",
            "@type": "xsd:integer"
        },
        "heartbeat_time": {
            "@id": "rec:heartbeat-time",
            "@type": "xsd:dateTime"
        },
        "result": "rec:result"
    }
}
