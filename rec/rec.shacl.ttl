@prefix exec: <https://secorolab.github.io/metamodels/execution-context#> .
@prefix obs: <https://secorolab.github.io/metamodels/observation#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rec: <https://secorolab.github.io/metamodels/rec#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

rec:RunExecutionShape
    a sh:NodeShape ;
    sh:targetSubjectsOf rec:run-id ;
    sh:class prov:Activity ;
    sh:class exec:ExecutionContext ;
    sh:property [
        sh:path rec:run-id ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path rec:status ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    # The run is a prov:Activity, so use native activity timing.
    # Elapsed is derived (endedAtTime - startedAtTime), not stored.
    sh:property [
        sh:path prov:startedAtTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
    ] ;
    sh:property [
        sh:path prov:endedAtTime ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
    ] ;
    sh:property [
        sh:path rec:repositories ;
        sh:class rec:Repository ;
    ] ;
    # sources: the source-code identity the run executed; its provenance is the
    # linked repositories and dependencies.
    sh:property [
        sh:path rec:sources ;
        sh:class prov:Entity ;
    ] ;
    sh:property [
        sh:path rec:dependencies ;
        sh:class rec:Dependency ;
    ] ;
    sh:property [
        sh:path rec:host-info ;
        sh:class rec:Host ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path rec:agents ;
        sh:class prov:Agent ;
    ] ;
    sh:property [
        sh:path rec:activities ;
        sh:class prov:Activity ;
    ] ;
    # resources: input entities the run consumed; each consumption is recorded as
    # a qualified usage (which entity, at what time) below.
    sh:property [
        sh:path rec:resources ;
        sh:class prov:Entity ;
    ] ;
    sh:property [
        sh:path prov:qualifiedUsage ;
        sh:node rec:UsageShape ;
    ] ;
    # artefacts: output entities the run produced, each linked to its generating
    # activity via a qualified generation (see ArtefactShape).
    sh:property [
        sh:path rec:artefacts ;
        sh:node rec:ArtefactShape ;
    ] ;
    sh:property [
        sh:path rec:metrics ;
        sh:class rec:Metric ;
    ] .

rec:UsageShape
    a sh:NodeShape ;
    sh:class prov:Usage ;
    sh:property [
        sh:path prov:entity ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class prov:Entity ;
    ] ;
    sh:property [
        sh:path prov:atTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
    ] .

rec:ArtefactShape
    a sh:NodeShape ;
    sh:class prov:Entity ;
    sh:property [
        sh:path prov:wasGeneratedBy ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class prov:Activity ;
    ] ;
    sh:property [
        sh:path prov:qualifiedGeneration ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:node rec:GenerationShape ;
    ] .

rec:GenerationShape
    a sh:NodeShape ;
    sh:class prov:Generation ;
    sh:property [
        sh:path prov:atTime ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
    ] .

rec:MetricShape
    a sh:NodeShape ;
    sh:targetClass rec:Metric ;
    sh:class qudt:Quantity ;
    sh:property [
        sh:path qudt:hasQuantityKind ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
    ] ;
    sh:property [
        sh:path qudt:value ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:or (
            [ sh:datatype xsd:integer ]
            [ sh:datatype xsd:decimal ]
            [ sh:datatype xsd:double ]
        ) ;
    ] ;
    sh:property [
        sh:path qudt:unit ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
    ] ;
    sh:property [
        sh:path rec:step ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
    ] .

rec:ObservationProviderShape
    a sh:NodeShape ;
    sh:targetClass obs:ObservationProvider ;
    sh:class prov:Agent .
