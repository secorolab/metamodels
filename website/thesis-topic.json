{
    "@context": {
        "@base": "https://secorolab.github.io/",
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "thesis-topic": "https://secorolab.github.io/metamodels/website/thesis-topic#",

        "ThesisTopic":    { "@id": "thesis-topic:ThesisTopic" },
        "TopicAdvisor":   { "@id": "thesis-topic:TopicAdvisor" },

        "title":             { "@id": "thesis-topic:title",             "@type": "xsd:string" },
        "description":       { "@id": "thesis-topic:description",       "@type": "xsd:string" },
        "educational-level": {
            "@id":        "thesis-topic:educational-level",
            "@type":      "xsd:string",
            "@container": "@set"
        },
        "date-posted":       { "@id": "thesis-topic:date-posted",       "@type": "xsd:date" },
        "valid-through":     { "@id": "thesis-topic:valid-through",     "@type": "xsd:date" },
        "prerequisites":     { "@id": "thesis-topic:prerequisites",     "@type": "xsd:string" },
        "url":               { "@id": "thesis-topic:url",               "@type": "@id" },

        "advisor": {
            "@id":        "thesis-topic:advisor",
            "@container": "@set",
            "@context": {
                "name": {
                    "@id": "thesis-topic:advisor-name"
                },
                "ref": {
                    "@id": "thesis-topic:advisor-ref",
                    "@type": "@id"
                }
            }
        }
    }
}
