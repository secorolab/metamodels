@prefix sh:          <http://www.w3.org/ns/shacl#> .
@prefix xsd:         <http://www.w3.org/2001/XMLSchema#> .
@prefix sh_sec:      <https://secorolab.github.io/metamodels/website/> .
@prefix job-opening: <https://secorolab.github.io/metamodels/website/job-opening#> .

sh_sec:JobOpeningShape
    a sh:NodeShape ;
    sh:targetClass job-opening:JobPosting ;
    sh:closed false ;

    sh:property [
        sh:path     job-opening:title ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minLength 3 ;
        sh:severity sh:Violation ;
        sh:message  "Job posting must have a title." ;
    ] ;

    sh:property [
        sh:path     job-opening:description ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message  "Job posting must have a description." ;
    ] ;

    sh:property [
        sh:path     job-opening:employment-type ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:in       ( "HiWi" "PhD" "PostDoc" "FullTime" "PartTime" "Internship" "Volunteer" ) ;
        sh:severity sh:Warning ;
        sh:message  "employment-type should be a recognised job type." ;
    ] ;

    sh:property [
        sh:path     job-opening:date-posted ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message  "Job posting must have a date-posted." ;
    ] ;

    sh:property [
        sh:path     job-opening:valid-through ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
        sh:severity sh:Warning ;
        sh:message  "valid-through should be a valid xsd:date." ;
    ] ;

    sh:property [
        sh:path     job-opening:qualifications ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path     job-opening:responsibilities ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path     job-opening:skills ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path     job-opening:incentive-compensation ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path     job-opening:hiring-organization ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:maxCount 1 ;
        sh:severity sh:Warning ;
        sh:message  "Job posting should reference a hiring-organization." ;
    ] ;

    sh:property [
        sh:path     job-opening:job-location ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path     job-opening:applicant-location-requirements ;
        sh:datatype xsd:string ;
    ] ;
.

sh_sec:JobOpeningOrganizationShape
    a sh:NodeShape ;
    sh:targetClass job-opening:Organization ;
    sh:closed false ;

    sh:property [
        sh:path     job-opening:org-name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message  "Organisation must have a name." ;
    ] ;

    sh:property [
        sh:path     job-opening:org-url ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] ;
.
