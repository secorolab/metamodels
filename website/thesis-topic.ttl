@prefix sh:           <http://www.w3.org/ns/shacl#> .
@prefix xsd:          <http://www.w3.org/2001/XMLSchema#> .
@prefix sh_sec:       <https://secorolab.github.io/metamodels/website/> .
@prefix thesis-topic: <https://secorolab.github.io/metamodels/website/thesis-topic#> .

sh_sec:ThesisTopicShape
    a sh:NodeShape ;
    sh:targetClass thesis-topic:ThesisTopic ;
    sh:closed false ;

    sh:property [
        sh:path     thesis-topic:title ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minLength 3 ;
        sh:severity sh:Violation ;
        sh:message  "Thesis topic must have a title." ;
    ] ;

    sh:property [
        sh:path     thesis-topic:description ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message  "Thesis topic must have a description." ;
    ] ;

    sh:property [
        sh:path     thesis-topic:educational-level ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:in       ( "BSc" "MSc" ) ;
        sh:severity sh:Violation ;
        sh:message  "Thesis topic must specify BSc, MSc, or both as educational-level values." ;
    ] ;

    sh:property [
        sh:path     thesis-topic:date-posted ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:severity sh:Violation ;
        sh:message  "Thesis topic must have a date-posted." ;
    ] ;

    sh:property [
        sh:path     thesis-topic:valid-through ;
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
        sh:severity sh:Warning ;
        sh:message  "valid-through should be a valid xsd:date." ;
    ] ;

    sh:property [
        sh:path     thesis-topic:advisor ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:node     sh_sec:ThesisTopicAdvisorShape ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message  "Thesis topic must reference at least one advisor object with ref and optional name." ;
    ] ;

    sh:property [
        sh:path     thesis-topic:prerequisites ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:path     thesis-topic:url ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
    ] ;
.

sh_sec:ThesisTopicAdvisorShape
    a sh:NodeShape ;
    sh:targetClass thesis-topic:TopicAdvisor ;
    sh:closed false ;

    sh:property [
        sh:path     thesis-topic:advisor-ref ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message  "Thesis topic advisor must have a ref." ;
    ] ;

    sh:property [
        sh:path     thesis-topic:advisor-name ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minLength 2 ;
        sh:message  "Thesis topic advisor may have a display name." ;
    ] ;
.
