@prefix map-ext: <https://secorolab.github.io/metamodels/task/map#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix map: <https://comp-rob2b.github.io/metamodels/task/map#> .
@prefix geom_coord: <https://comp-rob2b.github.io/metamodels/geometry/coordinates#> .
@prefix geom_coord_ext: <https://secorolab.github.io/metamodels/geometry/coordinates#> .
@prefix rbdyn_coord: <https://comp-rob2b.github.io/metamodels/newtonian-rigid-body-dynamics/coordinates#> .

# Secorolab coordinate-view extensions to the upstream comp-rob2b `map` vocabulary.
# The new view *classes* live in the secorolab namespace (map-ext:) rather than
# squatting in comp-rob2b's task/map#; the map: predicates (superobject,
# subobject, subspace, axis) are reused from upstream. Upstream map View classes
# (map:PoseCoordinateView, *TwistCoordinateView, ...) are inherently per-axis
# (they mandate map:axis), so these extensions cover the cases upstream does not.

# Coordinate view of the orientation sub-part of a pose. Without map:axis it exposes
# the whole orientation coordinate; with map:axis it exposes one x/y/z angle.
# Upstream map:PoseCoordinateView only models the position sub-part (subspace
# map:position), so orientation views use this extension (subspace map-ext:orientation).
map-ext:PoseOrientationView
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass map-ext:PoseOrientationView ;
    sh:property [
        sh:path map:superobject ;
        sh:class geom_coord:PoseCoordinate
    ] ;
    sh:property [
        sh:path map:subobject ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] ;
    sh:property [
        sh:path map:subspace ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:in ( map-ext:orientation )
    ] ;
    sh:property [
        sh:path map:axis ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:in ( map:x map:y map:z )
    ] .

# Coordinate view of the position sub-part of a pose, as the whole 3-vector.
# Upstream map:PoseCoordinateView is per-axis (mandates map:axis); this extension
# exposes the entire position vector (subspace map:position, no axis).
map-ext:PosePositionView
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass map-ext:PosePositionView ;
    sh:property [
        sh:path map:superobject ;
        sh:class geom_coord:PoseCoordinate
    ] ;
    sh:property [
        sh:path map:subobject ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] ;
    sh:property [
        sh:path map:subspace ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:in ( map:position )
    ] .

# Coordinate view of a wrench sub-part (force or torque) as the whole 3-vector.
# Upstream map:WrenchCoordinateView is per-axis (mandates map:axis); this extension
# exposes an entire 3-vector sub-part (subspace map:force or map:torque, no axis) —
# e.g. the input to a `Norm of <wrench>.force` / `Norm of <wrench>.torque` reduction.
map-ext:WrenchVectorView
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass map-ext:WrenchVectorView ;
    sh:property [
        sh:path map:superobject ;
        sh:class rbdyn_coord:WrenchCoordinate
    ] ;
    sh:property [
        sh:path map:subobject ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] ;
    sh:property [
        sh:path map:subspace ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:in ( map:force map:torque )
    ] .

# Per-axis view onto a pose difference: addresses the linear (position-difference)
# or angular (orientation-difference) part of a geom-coord-ext:PoseDifferenceCoordinate.
map-ext:PoseDifferenceView
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass map-ext:PoseDifferenceView ;
    sh:property [
        sh:path map:superobject ;
        sh:class geom_coord_ext:PoseDifferenceCoordinate
    ] ;
    sh:property [
        sh:path map:subobject ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] ;
    sh:property [
        sh:path map:subspace ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:in ( geom_coord_ext:linear geom_coord_ext:angular )
    ] .

map-ext:ComputeRotationFromPose
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass map-ext:ComputeRotationFromPose ;
    sh:property [
        sh:path map-ext:pose ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class geom_coord:PoseCoordinate
    ] ;
    sh:property [
        sh:path map-ext:rotation ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] .
