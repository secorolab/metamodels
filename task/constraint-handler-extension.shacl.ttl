@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix cstr_hdl: <https://comp-rob2b.github.io/metamodels/task/constraint-handler#> .
@prefix cstr-hdl-ext: <https://secorolab.github.io/metamodels/task/constraint-handler#> .
@prefix mot: <https://comp-rob2b.github.io/metamodels/task/motion-specification#> .

# Secorolab extension to the upstream comp-rob2b constraint-handler vocabulary.
# A feed-forward controller consumes a reference-signal instead of an error-signal.
# Upstream constraint-handler.ttl has no such controller (every upstream controller
# is feedback, carrying cstr_hdl:error-signal). The new class/predicate live in the
# secorolab namespace (cstr-hdl-ext:) rather than squatting in comp-rob2b's
# task/constraint-handler#; the upstream cstr_hdl: predicates (control-signal via the
# base cstr_hdl:Controller shape, error-signal) are reused.

cstr-hdl-ext:FeedForwardController
    a rdfs:Class, sh:NodeShape ;
    rdfs:subClassOf cstr_hdl:Controller ;
    sh:property [
        sh:path cstr-hdl-ext:reference-signal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] ;
    sh:property [
        sh:path cstr_hdl:error-signal ;
        sh:maxCount 0
    ] .

cstr-hdl-ext:VelocityProfile
    a rdfs:Class, sh:NodeShape ;
    sh:property [
        sh:path cstr-hdl-ext:max-velocity ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] ;
    sh:property [
        sh:path cstr-hdl-ext:max-acceleration ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] ;
    sh:property [
        sh:path cstr-hdl-ext:max-jerk ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] ;
    sh:property [
        sh:path cstr-hdl-ext:measured-velocity ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] ;
    sh:property [
        sh:path cstr-hdl-ext:shape ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:in ( "Trapezoidal" "SCurve" )
    ] .

cstr-hdl-ext:ProfiledController
    a sh:NodeShape ;
    sh:targetSubjectsOf cstr-hdl-ext:velocity-profile ;
    sh:class cstr_hdl:Controller ;
    sh:property [
        sh:path cstr-hdl-ext:velocity-profile ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class cstr-hdl-ext:VelocityProfile
    ] .

cstr-hdl-ext:UntilAggregateMonitor
    a sh:NodeShape ;
    sh:targetSubjectsOf cstr-hdl-ext:monitors-until ;
    sh:class cstr_hdl:Monitor ;
    sh:property [
        sh:path cstr-hdl-ext:monitors-until ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class mot:GuardedMotion
    ] .

cstr-hdl-ext:WhenAggregateMonitor
    a sh:NodeShape ;
    sh:targetSubjectsOf cstr-hdl-ext:monitors-when ;
    sh:class cstr_hdl:Monitor ;
    sh:property [
        sh:path cstr-hdl-ext:monitors-when ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class mot:GuardedMotion
    ] .

cstr-hdl-ext:FallbackMonitor
    a sh:NodeShape ;
    sh:targetSubjectsOf cstr-hdl-ext:fallback-motion ;
    sh:class cstr_hdl:Monitor ;
    sh:property [
        sh:path cstr-hdl-ext:fallback-motion ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class mot:GuardedMotion
    ] .

# Authored control-loop period on every ConstraintHandler (a qudt:Quantity of kind Time).
cstr-hdl-ext:ControlPeriod
    a sh:NodeShape ;
    sh:targetClass cstr_hdl:ConstraintHandler ;
    sh:property [
        sh:path cstr-hdl-ext:control-period ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] .
