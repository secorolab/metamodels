{
    "@context": {
        "@version": 1.1,
        "slv": "https://comp-rob2b.github.io/metamodels/task/solver-specification#",
        "slv-ext": "https://secorolab.github.io/metamodels/task/solver-specification#",

        "CommandForwardingAlgorithm": { "@id": "slv:CommandForwardingAlgorithm" },

        "regularization":   { "@id": "slv-ext:regularization",   "@type": "xsd:double" },
        "torque-limit":     { "@id": "slv-ext:torque-limit",     "@type": "xsd:double" },
        "max-linear-accel": { "@id": "slv-ext:max-linear-accel", "@type": "xsd:double" },
        "max-angular-accel": { "@id": "slv-ext:max-angular-accel", "@type": "xsd:double" },

        "CommandForwardingSolver": {
            "@id": "slv:CommandForwardingSolver",
            "@context": {
                "command-forwarding": { "@id": "slv:command-forwarding", "@type": "@id" },
                "solver":             { "@id": "slv:solver",             "@type": "@id" }
            }
        },

        "CommandForwardingSpecification": {
            "@id": "slv:CommandForwardingSpecification",
            "@context": {
                "attached-to":    { "@id": "slv:attached-to",    "@type": "@id" },
                "control-signal": { "@id": "slv:control-signal", "@type": "@id" }
            }
        }
    }
}
