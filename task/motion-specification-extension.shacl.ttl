@prefix mot-ext: <https://secorolab.github.io/metamodels/task/motion-specification#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix cstr: <https://comp-rob2b.github.io/metamodels/task/constraint#> .

mot-ext:ConstraintConjunction
    a sh:NodeShape ;
    sh:property [
        sh:path mot-ext:has-constraint ;
        sh:minCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class cstr:Constraint
    ] .

mot-ext:ConstraintDisjunction
    a sh:NodeShape ;
    sh:property [
        sh:path mot-ext:has-constraint ;
        sh:minCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class cstr:Constraint
    ] .
