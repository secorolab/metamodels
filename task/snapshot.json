{
    "@context": {
        "@version": 1.1,
        "snap": "https://secorolab.github.io/metamodels/task/snapshot#",

        "Snapshot": {
            "@id": "snap:Snapshot",
            "@context": {
                "snapshot-of": { "@id": "snap:snapshot-of", "@type": "@id" },
                "sampling": {
                    "@id": "snap:sampling",
                    "@type": "@vocab",
                    "@context": {
                        "initial-sampling": "snap:initial-sampling",
                        "event-triggered-sampling": "snap:event-triggered-sampling"
                    }
                },
                "trigger": {
                    "@id": "snap:trigger",
                    "@type": "@id"
                }
            }
        }
    }
}
