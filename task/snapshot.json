{
    "@context": {
        "@version": 1.1,
        "snap": "https://secorolab.github.io/metamodels/task/snapshot#",
        "prov": "http://www.w3.org/ns/prov#",

        "Snapshot": {
            "@id": "snap:Snapshot",
            "@context": {
                "snapshot-of": { "@id": "snap:snapshot-of", "@type": "@id" },
                "sampled-on": { "@id": "snap:sampled-on", "@type": "@id" }
            }
        },

        "Clock": { "@id": "snap:Clock" },
