# Secorolab validation mirror for comp-rob2b task/motion-specification.ttl.
# It keeps the upstream GuardedMotion terms, but explicitly allows WHEN/UNTIL
# guards to be a disjunction/conjunction of leaf constraints.

@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix cstr: <https://comp-rob2b.github.io/metamodels/task/constraint#> .
@prefix cstr-ext: <https://secorolab.github.io/metamodels/task/constraint#> .
@prefix mot: <https://comp-rob2b.github.io/metamodels/task/motion-specification#> .

mot:GuardedMotion
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass mot:GuardedMotion ;
    sh:property [
        sh:path mot:when ;
        sh:minCount 0 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:or (
            [ sh:class cstr:Constraint ]
            [ sh:class cstr-ext:ConstraintDisjunction ]
            [ sh:class cstr-ext:ConstraintConjunction ]
        )
    ] ;
    sh:property [
        sh:path mot:while ;
        sh:minCount 0 ;
        sh:class cstr:Constraint ;
        sh:nodeKind sh:BlankNodeOrIRI
    ] ;
    sh:property [
        sh:path mot:until ;
        sh:minCount 0 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:or (
            [ sh:class cstr:Constraint ]
            [ sh:class cstr-ext:ConstraintDisjunction ]
            [ sh:class cstr-ext:ConstraintConjunction ]
        )
    ] .
