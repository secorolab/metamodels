# Local development replacement for comp-rob2b task/motion-specification.ttl.
# It preserves the upstream GuardedMotion when/while/until shapes, but allows an
# UNTIL guard to be a disjunction/conjunction of leaf constraints (the secorolab
# `UNTIL any` / `UNTIL all` aggregates, modelled as mot-ext:Constraint{Dis,Con}junction)
# in addition to a single leaf cstr:Constraint.

@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix cstr: <https://comp-rob2b.github.io/metamodels/task/constraint#> .
@prefix mot: <https://comp-rob2b.github.io/metamodels/task/motion-specification#> .
@prefix mot-ext: <https://secorolab.github.io/metamodels/task/motion-specification#> .

mot:GuardedMotion
    a rdfs:Class, sh:NodeShape ;
    sh:property [
        sh:path mot:when ;
        sh:minCount 0 ;
        sh:class cstr:Constraint ;
        sh:nodeKind sh:BlankNodeOrIRI
    ] ;
    sh:property [
        sh:path mot:while ;
        sh:minCount 0 ;
        sh:class cstr:Constraint ;
        sh:nodeKind sh:BlankNodeOrIRI
    ] ;
    sh:property [
        sh:path mot:until ;
        sh:minCount 0 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:or (
            [ sh:class cstr:Constraint ]
            [ sh:class mot-ext:ConstraintDisjunction ]
            [ sh:class mot-ext:ConstraintConjunction ]
        )
    ] .
