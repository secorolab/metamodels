@prefix geom-rel: <https://comp-rob2b.github.io/metamodels/geometry/spatial-relations#> .
@prefix cstr-hdl-ext: <https://secorolab.github.io/metamodels/task/constraint-handler#> .
@prefix qkind: <http://qudt.org/vocab/quantitykind/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix traj: <https://secorolab.github.io/metamodels/task/trajectory#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

traj:ReferenceGenerator
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass traj:ReferenceGenerator ;
    sh:message "A reference generator must provide exactly one quantity reference." ;
    sh:property [ sh:path traj:reference ; sh:minCount 1 ; sh:maxCount 1 ; sh:class qudt:Quantity ] .

traj:Trajectory
    a rdfs:Class, sh:NodeShape ;
    rdfs:subClassOf traj:ReferenceGenerator ;
    sh:targetClass traj:Trajectory ;
    sh:message "A trajectory must be a reference generator with exactly one quantity reference." ;
    sh:node traj:ReferenceGenerator .

traj:PoseQuantityShape
    a sh:NodeShape ;
    sh:message "This value must be both a quantity and a pose." ;
    sh:class qudt:Quantity ;
    sh:class geom-rel:Pose .

traj:PoseTrajectoryShape
    a sh:NodeShape ;
    sh:message "This value must be a trajectory that produces exactly one pose quantity reference." ;
    sh:class traj:Trajectory ;
    sh:property [ sh:path traj:reference ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PoseQuantityShape ] .

traj:PositionQuantityShape
    a sh:NodeShape ;
    sh:message "This value must be a quantity whose quantity kind is position." ;
    sh:class qudt:Quantity ;
    sh:property [ sh:path qudt:hasQuantityKind ; sh:hasValue qkind:Position ] .

traj:DistanceQuantityShape
    a sh:NodeShape ;
    sh:message "This value must be a quantity whose quantity kind is distance." ;
    sh:class qudt:Quantity ;
    sh:property [ sh:path qudt:hasQuantityKind ; sh:hasValue qkind:Distance ] .

traj:DirectionQuantityShape
    a sh:NodeShape ;
    sh:message "This value must be a direction." ;
    sh:class geom-rel:Direction .

traj:PathParameterShape
    a sh:NodeShape ;
    sh:message "A path parameter must be a dimensionless quantity with exactly one numeric value in the interval [0, 1]." ;
    sh:class qudt:Quantity ;
    sh:property [ sh:path qudt:hasQuantityKind ; sh:hasValue qkind:Dimensionless ] ;
    sh:property [ sh:path qudt:numericValue ; sh:minCount 1 ; sh:maxCount 1 ; sh:minInclusive 0 ; sh:maxInclusive 1 ] .

traj:DimensionlessQuantityShape
    a sh:NodeShape ;
    sh:message "This value must be a dimensionless quantity." ;
    sh:class qudt:Quantity ;
    sh:property [ sh:path qudt:hasQuantityKind ; sh:hasValue qkind:Dimensionless ] .

traj:LinearVelocityQuantityShape
    a sh:NodeShape ;
    sh:message "This value must be a quantity whose quantity kind is linear velocity." ;
    sh:class qudt:Quantity ;
    sh:property [ sh:path qudt:hasQuantityKind ; sh:hasValue qkind:LinearVelocity ] .

traj:LinearAccelerationQuantityShape
    a sh:NodeShape ;
    sh:message "This value must be a quantity whose quantity kind is linear acceleration." ;
    sh:class qudt:Quantity ;
    sh:property [ sh:path qudt:hasQuantityKind ; sh:hasValue qkind:LinearAcceleration ] .

traj:LinearJerkQuantityShape
    a sh:NodeShape ;
    sh:message "This value must be a quantity whose quantity kind is linear jerk." ;
    sh:class qudt:Quantity ;
    sh:property [ sh:path qudt:hasQuantityKind ; sh:hasValue cstr-hdl-ext:LinearJerk ] .

traj:VelocityProfile
    a rdfs:Class, sh:NodeShape ;
    rdfs:subClassOf traj:ReferenceGenerator ;
    sh:targetClass traj:VelocityProfile ;
    sh:message "A velocity profile needs maximum velocity and acceleration, and produces one linear-velocity reference." ;
    sh:property [ sh:path traj:max-velocity ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:LinearVelocityQuantityShape ] ;
    sh:property [ sh:path traj:max-acceleration ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:LinearAccelerationQuantityShape ] ;
    sh:property [ sh:path traj:max-jerk ; sh:maxCount 1 ; sh:node traj:LinearJerkQuantityShape ] ;
    sh:property [ sh:path traj:measured-velocity ; sh:maxCount 1 ; sh:node traj:LinearVelocityQuantityShape ] ;
    sh:property [ sh:path traj:shape ; sh:datatype xsd:string ; sh:maxCount 1 ; sh:in ( "Trapezoidal" "SCurve" ) ] ;
    sh:property [ sh:path traj:reference ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:LinearVelocityQuantityShape ] .

traj:CartesianPoseInterpolation
    a rdfs:Class, sh:NodeShape ;
    rdfs:comment "Interpolates translation linearly and orientation along the shortest rotation." ;
    sh:targetClass traj:CartesianPoseInterpolation ;
    sh:message "A Cartesian pose interpolation needs start and goal poses, a unit-interval path parameter, and one pose trajectory." ;
    sh:property [ sh:path traj:start ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PoseQuantityShape ] ;
    sh:property [ sh:path traj:goal ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PoseQuantityShape ] ;
    sh:property [ sh:path traj:path-parameter ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PathParameterShape ] ;
    sh:property [ sh:path traj:trajectory ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PoseTrajectoryShape ] ;
    sh:property [ sh:path traj:profile ; sh:datatype xsd:string ; sh:maxCount 1 ; sh:in ( "Linear" "EaseIn" "EaseOut" "EaseInOut" ) ] .

traj:Circle
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass traj:Circle ;
    sh:message "A circle trajectory needs a start pose, centre, plane normal, path parameter, and pose trajectory." ;
    sh:property [ sh:path traj:start ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PoseQuantityShape ] ;
    sh:property [ sh:path traj:center ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PositionQuantityShape ] ;
    sh:property [ sh:path traj:plane-normal ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:DirectionQuantityShape ] ;
    sh:property [ sh:path traj:path-parameter ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PathParameterShape ] ;
    sh:property [ sh:path traj:trajectory ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PoseTrajectoryShape ] .

traj:Figure8
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass traj:Figure8 ;
    sh:message "A figure-eight trajectory needs an anchor pose, radius, plane normal, path parameter, pose trajectory, and supported form." ;
    sh:property [ sh:path traj:anchor ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PoseQuantityShape ] ;
    sh:property [ sh:path traj:radius ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:DistanceQuantityShape ] ;
    sh:property [ sh:path traj:plane-normal ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:DirectionQuantityShape ] ;
    sh:property [ sh:path traj:path-parameter ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PathParameterShape ] ;
    sh:property [ sh:path traj:trajectory ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PoseTrajectoryShape ] ;
    sh:property [ sh:path traj:form ; sh:datatype xsd:string ; sh:minCount 1 ; sh:maxCount 1 ; sh:in ( "Gerono" "Bernoulli" ) ] .

traj:Arc
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass traj:Arc ;
    sh:message "An arc trajectory needs start and end poses, amplitude, plane normal, path parameter, and pose trajectory." ;
    sh:property [ sh:path traj:start ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PoseQuantityShape ] ;
    sh:property [ sh:path traj:end ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PoseQuantityShape ] ;
    sh:property [ sh:path traj:amplitude ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:DistanceQuantityShape ] ;
    sh:property [ sh:path traj:plane-normal ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:DirectionQuantityShape ] ;
    sh:property [ sh:path traj:path-parameter ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PathParameterShape ] ;
    sh:property [ sh:path traj:trajectory ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PoseTrajectoryShape ] .

traj:Helix
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass traj:Helix ;
    sh:message "A helix trajectory needs a start pose, centre, axis, pitch, revolutions, path parameter, and pose trajectory." ;
    sh:property [ sh:path traj:start ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PoseQuantityShape ] ;
    sh:property [ sh:path traj:center ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PositionQuantityShape ] ;
    sh:property [ sh:path traj:axis ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:DirectionQuantityShape ] ;
    sh:property [ sh:path traj:pitch ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:DistanceQuantityShape ] ;
    sh:property [ sh:path traj:revolutions ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:DimensionlessQuantityShape ] ;
    sh:property [ sh:path traj:path-parameter ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PathParameterShape ] ;
    sh:property [ sh:path traj:trajectory ; sh:minCount 1 ; sh:maxCount 1 ; sh:node traj:PoseTrajectoryShape ] .
