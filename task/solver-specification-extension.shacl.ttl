@prefix slv:      <https://comp-rob2b.github.io/metamodels/task/solver-specification#> .
@prefix slv-ext:  <https://secorolab.github.io/metamodels/task/solver-specification#> .
@prefix cstr-hdl-ext: <https://secorolab.github.io/metamodels/task/constraint-handler#> .
@prefix kc_ent:   <https://comp-rob2b.github.io/metamodels/kinematic-chain/structural-entities#> .
@prefix geom-rel: <https://comp-rob2b.github.io/metamodels/geometry/spatial-relations#> .
@prefix qudt:     <http://qudt.org/schema/qudt/> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:       <http://www.w3.org/ns/shacl#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .

# Secorolab extension to the upstream comp-rob2b solver-specification.
# Models a pass-through "command forwarding" driver that drives a single joint
# actuator with a feed-forward control signal (used for gripper actuation in
# motion-spec-dsl). The upstream solver-specification.ttl does not cover this
# case because slv:SolverWithInputAndOutput restricts slv:solver to dynamics
# algorithms (RNEA / ABA / ACHD).
#
# The new classes/predicate live in the secorolab namespace (slv-ext:) rather
# than squatting in comp-rob2b's slv#; the upstream slv:attached-to predicate is
# reused for the target joint.

slv-ext:CommandForwardingDriver
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass slv-ext:CommandForwardingDriver ;
    sh:property [
        sh:path slv-ext:forwards-command ;
        sh:minCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class slv-ext:ForwardedCommand
    ] .

slv-ext:ForwardedCommand
    a rdfs:Class, sh:NodeShape ;
    sh:targetClass slv-ext:ForwardedCommand ;
    sh:property [
        sh:path slv:attached-to ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:class kc_ent:Joint
    ] ;
    sh:property [
        sh:path slv-ext:command-signal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] .

# Optional per-solver control-loop tuning:
# - regularization: DLS (Tikhonov) singularity-robustness lambda for the constrained
#   joint-acceleration solve. RNE-only (enforced in DSL validation); a numerical
#   regularization of the inverse, distinct from a physical (velocity) damping.
# - torque-limit / max-linear-accel / max-angular-accel are legacy scalar fields.
#   New models should use explicit cstr-hdl-ext:limits links to
#   slv-ext:TorqueSaturation or slv-ext:AccelerationSaturation nodes.
slv:SolverWithInputAndOutput
    a sh:NodeShape ;
    sh:targetClass slv:SolverWithInputAndOutput ;
    sh:property [
        sh:path slv-ext:regularization ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:datatype xsd:double ;
        sh:minExclusive 0
    ] ;
    sh:property [
        sh:path slv-ext:torque-limit ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] ;
    sh:property [
        sh:path slv-ext:max-linear-accel ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] ;
    sh:property [
        sh:path slv-ext:max-angular-accel ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] ;
    sh:property [
        sh:path cstr-hdl-ext:limits ;
        sh:minCount 0 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class slv-ext:TorqueSaturation
    ] .

slv:AccelerationConstraint
    a sh:NodeShape ;
    sh:targetClass slv:AccelerationConstraint ;
    sh:property [
        sh:path cstr-hdl-ext:limits ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class slv-ext:AccelerationSaturation
    ] .

slv-ext:AccelerationSaturation
    a rdfs:Class, sh:NodeShape ;
    rdfs:subClassOf cstr-hdl-ext:Saturation ;
    sh:targetClass slv-ext:AccelerationSaturation ;
    sh:property [
        sh:path cstr-hdl-ext:input-signal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] ;
    sh:property [
        sh:path cstr-hdl-ext:output-signal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] .

slv-ext:TorqueSaturation
    a rdfs:Class, sh:NodeShape ;
    rdfs:subClassOf cstr-hdl-ext:Saturation ;
    sh:targetClass slv-ext:TorqueSaturation ;
    sh:property [
        sh:path cstr-hdl-ext:input-signal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] ;
    sh:property [
        sh:path cstr-hdl-ext:output-signal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] .

# Direction-aligned ACHD acceleration constraint: the secorolab-layer sibling of
# upstream slv:AxisAligned. Where AxisAligned fills the constraint's Jacobian
# column with a fixed unit axis (x/y/z), DirectionAligned fills it with a
# runtime unit geom-rel:Direction (e.g. from geom-op:PoseToDirection on a
# distance-between-two-poses relative pose) -- lets a distance control
# constraint (`keeping distance between <A> and <B> equal to <target>`) drive
# the solver like any other Cartesian acceleration constraint.
slv-ext:DirectionAligned
    a rdfs:Class, sh:NodeShape ;
    sh:property [
        sh:path slv:subspace ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:in ( slv:angular-acceleration slv:linear-acceleration )
    ] ;
    sh:property [
        sh:path slv-ext:direction ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class geom-rel:Direction
    ] .
