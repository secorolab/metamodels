@prefix slv:     <https://comp-rob2b.github.io/metamodels/task/solver-specification#> .
@prefix slv-ext: <https://secorolab.github.io/metamodels/task/solver-specification#> .
@prefix kc_ent: <https://comp-rob2b.github.io/metamodels/kinematic-chain/structural-entities#> .
@prefix qudt:   <http://qudt.org/schema/qudt/> .
@prefix sh:     <http://www.w3.org/ns/shacl#> .

# Secorolab extension to the upstream comp-rob2b solver-specification.
# Models a pass-through "command forwarding" solver that drives a single joint
# actuator with a feed-forward control signal (used for gripper actuation in
# motion-spec-dsl). The upstream solver-specification.ttl does not cover this
# case because slv:SolverWithInputAndOutput restricts slv:solver to dynamics
# algorithms (RNEA / ABA / ACHD).
#
# The new classes/predicate live in the secorolab namespace (slv-ext:) rather
# than squatting in comp-rob2b's slv#; the upstream slv: predicates (solver,
# attached-to, control-signal) are reused.

slv-ext:CommandForwardingSolver
    a sh:NodeShape ;
    sh:targetClass slv-ext:CommandForwardingSolver ;
    sh:property [
        sh:path slv-ext:command-forwarding ;
        sh:minCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class slv-ext:CommandForwardingSpecification
    ] ;
    sh:property [
        sh:path slv:solver ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:in ( slv-ext:CommandForwardingAlgorithm )
    ] .

slv-ext:CommandForwardingSpecification
    a sh:NodeShape ;
    sh:targetClass slv-ext:CommandForwardingSpecification ;
    sh:property [
        sh:path slv:attached-to ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:class kc_ent:Joint
    ] ;
    sh:property [
        sh:path slv-ext:control-signal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] .
