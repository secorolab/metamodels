{
    "@context": {
        "@version": 1.1,
        "map": "https://comp-rob2b.github.io/metamodels/task/map#",
        "map-ext": "https://secorolab.github.io/metamodels/task/map#",

        "PoseCoordinateView": {
            "@id": "map-ext:PoseCoordinateView",
            "@context": {
                "superobject": {
                    "@id": "map:superobject",
                    "@type": "@id"
                },
                "subobject": {
                    "@id": "map:subobject",
                    "@type": "@id"
                },
                "subspace": {
                    "@id": "map:subspace",
                    "@type": "@vocab",
                    "@context": {
                        "position": "map:position",
                        "orientation": "map-ext:orientation"
                    }
                },
                "axis": {
                    "@id": "map:axis",
                    "@type": "@vocab",
                    "@context": {
                        "x": "map:x",
                        "y": "map:y",
                        "z": "map:z"
                    }
                }
            }
        },
        "WrenchVectorView": {
            "@id": "map-ext:WrenchVectorView",
            "@context": {
                "subspace": {
                    "@id": "map:subspace",
                    "@type": "@vocab",
                    "@context": {
                        "force": "map:force",
                        "torque": "map:torque"
                    }
                }
            }
        },
        "PoseDifferenceView": {
            "@id": "map-ext:PoseDifferenceView",
            "@context": {
                "subspace": {
                    "@id": "map:subspace",
                    "@type": "@vocab",
                    "@context": {
                        "linear": "map-ext:linear",
                        "angular": "map-ext:angular"
                    }
                },
                "axis": {
                    "@id": "map:axis",
                    "@type": "@vocab",
                    "@context": {
                        "x": "map:x",
                        "y": "map:y",
                        "z": "map:z"
                    }
                }
            }
        }
    }
}
