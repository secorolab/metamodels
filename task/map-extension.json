{
    "@context": {
        "@version": 1.1,
        "map": "https://comp-rob2b.github.io/metamodels/task/map#",
        "map-ext": "https://secorolab.github.io/metamodels/task/map#",
        "geom-coord": "https://comp-rob2b.github.io/metamodels/geometry/coordinates#",

        "superobject": { "@id": "map:superobject", "@type": "@id" },
        "subobject": { "@id": "map:subobject", "@type": "@id" },
        "subspace": {
            "@id": "map:subspace",
            "@type": "@vocab",
            "@context": {
                "orientation": "map-ext:orientation",
                "position": "map:position",
                "force": "map:force",
                "torque": "map:torque",
                "linear": "geom-coord:linear",
                "angular": "geom-coord:angular"
            }
        },
        "axis": {
            "@id": "map:axis",
            "@type": "@vocab",
            "@context": { "x": "map:x", "y": "map:y", "z": "map:z" }
        },
        "pose": { "@id": "map-ext:pose", "@type": "@id" },
        "rotation": { "@id": "map-ext:rotation", "@type": "@id" },

        "PoseOrientationView": "map-ext:PoseOrientationView",
        "PosePositionView": "map-ext:PosePositionView",
        "WrenchVectorView": "map-ext:WrenchVectorView",
        "PoseDifferenceView": "map-ext:PoseDifferenceView",
        "ComputeRotationFromPose": "map-ext:ComputeRotationFromPose"
    }
}
