{
    "@context": {
        "@version": 1.1,
        "xsd": "http://www.w3.org/2001/XMLSchema#",
        "traj": "https://secorolab.github.io/metamodels/task/trajectory#",

        "ReferenceGenerator": "traj:ReferenceGenerator",
        "reference": { "@id": "traj:reference", "@type": "@id" },
        "Trajectory": {
            "@id": "traj:Trajectory",
            "@context": {
                "reference": { "@id": "traj:reference", "@type": "@id" }
            }
        },
        "Progress": "traj:Progress",
        "LinearJerk": "traj:LinearJerk",
        "VelocityProfile": {
            "@id": "traj:VelocityProfile",
            "@context": {
                "max-velocity": {
                    "@id": "traj:max-velocity",
                    "@type": "@id"
                },
                "max-acceleration": {
                    "@id": "traj:max-acceleration",
                    "@type": "@id"
                },
                "max-jerk": {
                    "@id": "traj:max-jerk",
                    "@type": "@id"
                },
                "measured-velocity": {
                    "@id": "traj:measured-velocity",
                    "@type": "@id"
                },
                "shape": {
                    "@id": "traj:shape",
                    "@type": "xsd:string"
                }
            }
        },

        "Lerp": {
            "@id": "traj:Lerp",
            "@context": {
                "start": {
                    "@id": "traj:start",
                    "@type": "@id"
                },
                "goal": {
                    "@id": "traj:goal",
                    "@type": "@id"
                },
                "alpha": {
                    "@id": "traj:alpha",
                    "@type": "@id"
                },
                "trajectory": {
                    "@id": "traj:trajectory",
                    "@type": "@id"
                },
                "profile": {
                    "@id": "traj:profile",
                    "@type": "xsd:string"
                }
            }
        },

        "Circle": {
            "@id": "traj:Circle",
            "@context": {
                "start": {
                    "@id": "traj:start",
                    "@type": "@id"
                },
                "center": {
                    "@id": "traj:center",
                    "@type": "@id"
                },
                "plane-normal": {
                    "@id": "traj:plane-normal",
                    "@type": "@id"
                },
                "alpha": {
                    "@id": "traj:alpha",
                    "@type": "@id"
                },
                "trajectory": {
                    "@id": "traj:trajectory",
                    "@type": "@id"
                }
            }
        },

        "Arc": {
            "@id": "traj:Arc",
            "@context": {
                "start": {
                    "@id": "traj:start",
                    "@type": "@id"
                },
                "end": {
                    "@id": "traj:end",
                    "@type": "@id"
                },
                "amplitude": {
                    "@id": "traj:amplitude",
                    "@type": "@id"
                },
                "plane-normal": {
                    "@id": "traj:plane-normal",
                    "@type": "@id"
                },
                "alpha": {
                    "@id": "traj:alpha",
                    "@type": "@id"
                },
                "trajectory": {
                    "@id": "traj:trajectory",
                    "@type": "@id"
                }
            }
        },

        "Figure8": {
            "@id": "traj:Figure8",
            "@context": {
                "anchor": {
                    "@id": "traj:anchor",
                    "@type": "@id"
                },
                "radius": {
                    "@id": "traj:radius",
                    "@type": "@id"
                },
                "plane-normal": {
                    "@id": "traj:plane-normal",
                    "@type": "@id"
                },
                "alpha": {
                    "@id": "traj:alpha",
                    "@type": "@id"
                },
                "trajectory": {
                    "@id": "traj:trajectory",
                    "@type": "@id"
                },
                "form": {
                    "@id": "traj:form",
                    "@type": "xsd:string"
                }
            }
        },

        "Helix": {
            "@id": "traj:Helix",
            "@context": {
                "start": {
                    "@id": "traj:start",
                    "@type": "@id"
                },
                "center": {
                    "@id": "traj:center",
                    "@type": "@id"
                },
                "axis": {
                    "@id": "traj:axis",
                    "@type": "@id"
                },
                "pitch": {
                    "@id": "traj:pitch",
                    "@type": "@id"
                },
                "revolutions": {
                    "@id": "traj:revolutions",
                    "@type": "@id"
                },
                "alpha": {
                    "@id": "traj:alpha",
                    "@type": "@id"
                },
                "trajectory": {
                    "@id": "traj:trajectory",
                    "@type": "@id"
                }
            }
        }
    }
}
