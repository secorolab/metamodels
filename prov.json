        "entity": { "@id": "prov:entity", "@type": "@id" },
        "activity": { "@id": "prov:activity", "@type": "@id" },
        "agent": { "@id": "prov:agent", "@type": "@id" },
        "hadRole": { "@id": "prov:hadRole", "@type": "@id" },
        "hadPlan": { "@id": "prov:hadPlan", "@type": "@id" },
        "hadActivity": { "@id": "prov:hadActivity", "@type": "@id" },
