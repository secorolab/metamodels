@prefix mj:         <https://secorolab.github.io/metamodels/simulation/mujoco#> .
@prefix geom-coord: <https://comp-rob2b.github.io/metamodels/geometry/coordinates#> .
@prefix geom-rel:   <https://comp-rob2b.github.io/metamodels/geometry/spatial-relations#> .
@prefix sh:         <http://www.w3.org/ns/shacl#> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .

mj:MjcfModel
    a sh:NodeShape ;
    sh:targetClass mj:MjcfModel .

mj:MuJoCoBody
    a sh:NodeShape ;
    sh:targetClass mj:MuJoCoBody ;
    sh:property [
        sh:path mj:body-name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path mj:tool-body ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:class mj:MuJoCoBody
    ] ;
    sh:property [
        sh:path mj:tcp-site ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:class mj:MuJoCoSite
    ] ;
    sh:property [
        sh:path mj:friction-slide ;
        sh:maxCount 1 ;
        sh:datatype xsd:double ;
        sh:minInclusive 0
    ] ;
    sh:property [
        sh:path mj:friction-torsion ;
        sh:maxCount 1 ;
        sh:datatype xsd:double ;
        sh:minInclusive 0
    ] ;
    sh:property [
        sh:path mj:friction-roll ;
        sh:maxCount 1 ;
        sh:datatype xsd:double ;
        sh:minInclusive 0
    ] ;
    sh:property [
        sh:path mj:color ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:class mj:ColorRGBA
    ] ;
    sh:property [
        sh:path mj:trace-target ;
        sh:datatype xsd:string
    ] .

# Grouped RGBA colour value node, shared by scene objects and the trajectory
# trace overlay. Each channel is a double in [0, 1].
mj:ColorRGBA
    a sh:NodeShape ;
    sh:targetClass mj:ColorRGBA ;
    sh:property [
        sh:path mj:color-r ;
        sh:maxCount 1 ;
        sh:datatype xsd:double ;
        sh:minInclusive 0 ;
        sh:maxInclusive 1
    ] ;
    sh:property [
        sh:path mj:color-g ;
        sh:maxCount 1 ;
        sh:datatype xsd:double ;
        sh:minInclusive 0 ;
        sh:maxInclusive 1
    ] ;
    sh:property [
        sh:path mj:color-b ;
        sh:maxCount 1 ;
        sh:datatype xsd:double ;
        sh:minInclusive 0 ;
        sh:maxInclusive 1
    ] ;
    sh:property [
        sh:path mj:color-a ;
        sh:maxCount 1 ;
        sh:datatype xsd:double ;
        sh:minInclusive 0 ;
        sh:maxInclusive 1
    ] .

mj:MuJoCoSite
    a sh:NodeShape ;
    sh:targetClass mj:MuJoCoSite ;
    sh:property [
        sh:path mj:site-name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string
    ] .

# Live end-effector trajectory trace overlay drawn in the MuJoCo viewer.
# Purely a visualisation concern: ignored in headless runs.
mj:TrajectoryTrace
    a sh:NodeShape ;
    sh:targetClass mj:TrajectoryTrace ;
    sh:property [
        sh:path mj:trace-enabled ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:boolean
    ] ;
    sh:property [
        sh:path mj:trace-length ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 2 ;
        sh:maxInclusive 8192
    ] ;
    sh:property [
        sh:path mj:color ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:class mj:ColorRGBA
    ] .

# A workspace may reference at most one trajectory trace overlay.
mj:TraceHostShape
    a sh:NodeShape ;
    sh:targetSubjectsOf mj:has-trace ;
    sh:property [
        sh:path mj:has-trace ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:class mj:TrajectoryTrace
    ] .

# Targets any subject that declares mj:attach-to-body, regardless of whether
# the DSL emits an explicit rdf:type mj:Attachment.
mj:Attachment
    a sh:NodeShape ;
    sh:targetSubjectsOf mj:attach-to-body ;
    sh:property [
        sh:path mj:attach-to-body ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:xone (
            [ sh:class mj:MuJoCoBody ]
            [ sh:class mj:MuJoCoSite ]
        )
    ] ;
    sh:property [
        sh:path mj:attach-kind ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "body" "site" )
    ] ;
    sh:property [
        sh:path mj:attach-name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path mj:attach-position ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class geom-coord:VectorXYZ
    ] ;
    sh:property [
        sh:path mj:attach-orientation ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class geom-rel:Orientation
    ] ;
    sh:property [
        sh:path mj:attach-prefix ;
        sh:maxCount 1 ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path mj:actuator-name ;
        sh:maxCount 1 ;
        sh:datatype xsd:string
    ] ;
    sh:property [
        sh:path mj:open-command ;
        sh:maxCount 1 ;
        sh:datatype xsd:double
    ] ;
    sh:property [
        sh:path mj:closed-command ;
        sh:maxCount 1 ;
        sh:datatype xsd:double
    ] ;
    sh:property [
        sh:path mj:prefix ;
        sh:maxCount 1 ;
        sh:datatype xsd:string
    ] .
