@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix snap: <https://secorolab.github.io/metamodels/snapshot#> .

# A Snapshot is a sample-and-hold of a fluent, defined on a sampling clock.
# task-clock: sampled once on the task/init clock, held for the whole run.
# entry-clock: re-sampled on each state-activation (entry) clock tick.
snap:task-clock a snap:Clock .
snap:entry-clock a snap:Clock .

snap:Snapshot
    a sh:NodeShape ;
    sh:property [
        sh:path snap:snapshot-of ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:class qudt:Quantity
    ] ;
    sh:property [
        sh:path snap:sampled-on ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:in ( snap:task-clock snap:entry-clock )
    ] .
